{% extends 'base.html.twig' %}

{% block title %}{{ task.title }}{% endblock %}

{% block body %}
    <h1>{{ task.title }}</h1>

    <p style="white-space: pre-wrap">{{ task.description|default('Nincs leírás.') }}</p>
    <p>Állapot: {{ task.done ? 'Kész' : 'Folyamatban' }}</p>
    <p>Létrehozva: {{ task.createdAt|date('Y-m-d H:i') }}</p>

    <a href="{{ path('app_task_edit', {id: task.id}) }}">Szerkesztés</a>
    <a href="{{ path('app_task_index') }}">Vissza a listához</a>
{% endblock %}
